        if not title and soup.title: title=soup.title.string or ''
        episodes=[]
        ep=soup.find(class_='allepcont')
        if ep:
            for a in ep.find_all('a',href=True)[:60]:
                t=a.text.strip() or a.get('title','')
                if t: episodes.append({'href':a['href'],'title':t})
        related=[]
        seen_r=set()
        for item in soup.find_all(class_='Small--Box')[:10]:
            a=item.find('a',href=True)
            if not a or a['href'] in seen_r: continue
            seen_r.add(a['href'])
            h3=item.find('h3')
            t=h3.text.strip() if h3 else a.get('title','')
            if t: related.append({'href':a['href'],'title':t,'img':get_img(item.find('img'))})
        embed_url=get_embed_from_watch(url)
        links=get_video_links(embed_url) if embed_url else []
        return jsonify({'links':links,'title':title,'related':related,'episodes':episodes,'embed_url':embed_url or ''})
    except Exception as e:
        return jsonify({'error':str(e),'links':[]})

