from flask import Flask, request, jsonify, Response
import requests, re
from bs4 import BeautifulSoup

app = Flask(__name__)

HEADERS = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
    'Accept-Language': 'ar,en;q=0.9',
    'Referer': 'https://topcinemaa.com/',
}

def get_img(tag):
    if not tag: return ''
    return tag.get('data-src','') or tag.get('src','') or ''

def decode_eval(text):
    s = text.find('eval(function(p,a,c,k,e,d)')
    if s == -1: return ''
    block = text[s:s+15000]
    m = re.search(r"}\('(.+)',(\d+),(\d+),'(.+)'\.split\('\|'\)\)\)", block, re.S)
    if not m: return ''
    p,a,c,k = m.group(1),int(m.group(2)),int(m.group(3)),m.group(4)
    kw = k.split('|')
    def tb(n,b):
        ch='0123456789abcdefghijklmnopqrstuvwxyz'
        if n==0: return '0'
        r=''
        while n: r=ch[n%b]+r; n//=b
        return r
    res=p
    for i in range(c-1,-1,-1):
        key=tb(i,a)
        if i<len(kw) and kw[i]:
            res=re.sub(r'\b'+re.escape(key)+r'\b',kw[i],res)
    return res

def get_video_links(embed_url):
    try:
        h={'User-Agent':HEADERS['User-Agent'],'Referer':'https://topcinemaa.com/'}
        r=requests.get(embed_url,headers=h,timeout=15)
        decoded=decode_eval(r.text)
        if not decoded: return []
        mp4s=re.findall(r'https?://[^\s"\'\\,\)]+\.mp4[^\s"\'\\,\)]*',decoded)
        labels=re.findall(r'label:"([^"]+)"',decoded)
        return [{'url':u,'label':labels[i] if i<len(labels) else f'جودة {i+1}'} for i,u in enumerate(mp4s)]
    except: return []

def get_embed_from_watch(url):
    try:
        watch_url = url.rstrip('/') + '/watch/'
        r = requests.get(watch_url, headers=HEADERS, timeout=15)
        soup = BeautifulSoup(r.text, 'html.parser')
        for iframe in soup.find_all('iframe'):
            src = iframe.get('src','') or iframe.get('data-src','')
            if src and 'vidtube' in src:
                return src
        r2 = requests.get(url, headers=HEADERS, timeout=15)
        soup2 = BeautifulSoup(r2.text, 'html.parser')
        for iframe in soup2.find_all('iframe'):
            src = iframe.get('src','') or iframe.get('data-src','')
            if src and ('vidtube' in src or 'embed' in src.lower()):
                return src
    except: pass
    return None

def get_items(soup):
    items=[]
    seen=set()
    for item in soup.find_all(class_=['Block--Item','Small--Box']):
        a=item.find('a',href=True)
        if not a: continue
        href=a.get('href','')
        if not href or href in seen: continue
        seen.add(href)
        h3=item.find('h3')
        title=h3.text.strip() if h3 else a.get('title','')
        img=get_img(item.find('img'))
        ribbon=item.find(class_='ribbon')
        quality=ribbon.text.strip() if ribbon else ''
        genres=[]
        for li in item.find_all('li'):
            t=li.text.strip()
            if t and not any(x in t for x in ['BluRay','WEB','HD','SD','FHD','720','1080','480','240','p ']):
                genres.append(t)
        if title:
            items.append({'href':href,'title':title,'img':img,'quality':quality,'genres':genres[:3]})
    return items

# proxy لجلب الفيديو وحل مشكلة CORS
@app.route('/proxy')
def proxy():
    video_url = request.args.get('url','')
    if not video_url:
        return 'no url', 400
    try:
        range_header = request.headers.get('Range','')
        h = {
            'User-Agent': HEADERS['User-Agent'],
            'Referer': 'https://vidtube.one/',
            'Origin': 'https://vidtube.one',
        }
        if range_header:
            h['Range'] = range_header
        rv = requests.get(video_url, headers=h, stream=True, timeout=30)
        def generate():
            for chunk in rv.iter_content(chunk_size=65536):
                if chunk:
                    yield chunk
        resp_headers = {
            'Content-Type': rv.headers.get('Content-Type','video/mp4'),
            'Accept-Ranges': 'bytes',
            'Access-Control-Allow-Origin': '*',
        }
        if 'Content-Length' in rv.headers:
            resp_headers['Content-Length'] = rv.headers['Content-Length']
        if 'Content-Range' in rv.headers:
            resp_headers['Content-Range'] = rv.headers['Content-Range']
        return Response(generate(), status=rv.status_code, headers=resp_headers)
    except Exception as e:
        return str(e), 500

