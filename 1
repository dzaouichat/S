def get_page(url):
    try:
        url = unquote(url)
        r   = SESSION.get(url, timeout=15, allow_redirects=True)
        return r if r.status_code == 200 else None
    except:
        return None

def extract_meta(html_text):
    csrf   = re.search(r"csrf__token['\"\s:]+['\"](\w+)['\"]", html_text)
    postid = re.search(r"psot_id['\"\s:]+['\"](\d+)['\"]", html_text)
    return (
        csrf.group(1)   if csrf   else "",
        postid.group(1) if postid else ""
    )

def get_watch_server(post_id, quality, server, csrf_token):
    try:
        r    = SESSION.post(f"{BASE}/get__watch__server/", data={
            "post_id":    post_id,
            "quality":    quality,
            "server":     server,
            "csrf_token": csrf_token
        }, timeout=10)
        data = r.json()
        if data.get("type") == "success":
            data["iframe_src"] = data.get("server", "")
        return data
    except:
        return {}

def get_servers(post_id, csrf_token):
    available = []
    for quality in ["1080", "720", "480"]:
        try:
            r    = SESSION.post(f"{BASE}/get__watch__server/", data={
                "post_id":    post_id,
                "quality":    quality,
                "server":     "1",
                "csrf_token": csrf_token
            }, timeout=8)
            data = r.json()
            if data.get("type") == "success" and data.get("server"):
                available.append({"label": f"🎬 {quality}p", "value": quality})
        except:
            pass
    return {"qualities": available}

def parse_content_list(html_text):
    soup = BeautifulSoup(html_text, "html.parser")
    results, seen = [], set()
    skip = [
        "/category/", "/page/", "/movies/", "/series/",
        "/recently/", "/trend/", "/find/", "/main", "/home",
        "/privacy", "/dmca", "/orders", "/wp-", "/سيرفر",
        "/selary/", "/the-bluff/", "/whistle/"
    ]
    for a in soup.find_all("a", href=True):
        href = unquote(a["href"])
        if BASE not in href: continue
        if href in seen: continue
        if any(s in href for s in skip): continue
        img    = a.find("img")
        poster = (img.get("data-src") or img.get("src") or "") if img else ""
        title  = a.get_text(separator=" ", strip=True)[:80]
        if title and len(title) > 2:
            seen.add(href)
            results.append({"title": title, "url": href, "poster": poster})
    return results

