def extract_from_vidara(embed_url):
    """vidara.to - يستخدم /api/stream?filecode=xxx"""
    try:
        filecode = embed_url.rstrip("/").split("/")[-1]
        api_url  = f"https://vidara.to/api/stream?filecode={filecode}"
        r = SESSION.get(api_url, headers={
            "User-Agent": HEADERS["User-Agent"],
            "Referer": embed_url
        }, timeout=10)
        data = r.json()
        streaming_url = data.get("streaming_url", "")
        return {
            "url":   streaming_url,
            "type":  "m3u8" if ".m3u8" in streaming_url else "mp4",
            "title": data.get("title", ""),
            "thumb": data.get("thumbnail", "")
        }
    except:
        return {}

def extract_from_vidmoly(embed_url):
    """vidmoly.net - M3U8 مباشر في HTML"""
    try:
        r = SESSION.get(embed_url, headers={
            "User-Agent": HEADERS["User-Agent"],
            "Referer": "https://asd.pics/"
        }, timeout=10)
        m3u8 = re.findall(r'https?://[^\s"\'\\<>]+\.m3u8[^\s"\'\\<>]*', r.text)
        mp4  = re.findall(r'https?://[^\s"\'\\<>]+\.mp4[^\s"\'\\<>]*',  r.text)
        url  = m3u8[0] if m3u8 else (mp4[0] if mp4 else "")
        return {
            "url":  url,
            "type": "m3u8" if m3u8 else "mp4"
        }
    except:
        return {}

def extract_from_voe(embed_url):
    """voe.sx - يعمل redirect ثم نستخرج منه"""
    try:
        filecode   = embed_url.rstrip("/").split("/")[-1]
        redirect   = f"https://lancewhosedifficult.com/e/{filecode}"
        r = SESSION.get(redirect, headers={
            "User-Agent": HEADERS["User-Agent"],
            "Referer": "https://asd.pics/"
        }, timeout=10, allow_redirects=True)
        m3u8 = re.findall(r'https?://[^\s"\'\\<>]+\.m3u8[^\s"\'\\<>]*', r.text)
        mp4  = re.findall(r'https?://[^\s"\'\\<>]+\.mp4[^\s"\'\\<>]*',  r.text)
        # بحث في JS
        sources = re.findall(r'"(?:file|src|url)"\s*:\s*"([^"]+)"', r.text)
        for s in sources:
            if ".m3u8" in s: m3u8.append(s)
            if ".mp4"  in s: mp4.append(s)
        url = m3u8[0] if m3u8 else (mp4[0] if mp4 else "")
        return {
            "url":  url,
            "type": "m3u8" if m3u8 else "mp4"
        }
    except:
        return {}

def extract_direct_url(embed_url):
    """يختار الدالة المناسبة حسب الموقع"""
    if not embed_url:
        return {}
    if "vidara" in embed_url:
        return extract_from_vidara(embed_url)
    if "vidmoly" in embed_url:
        return extract_from_vidmoly(embed_url)
    if "voe.sx" in embed_url or "lancewhosedifficult" in embed_url:
        return extract_from_voe(embed_url)
    # محاولة عامة لأي موقع آخر
    try:
        r = SESSION.get(embed_url, headers={
            "User-Agent": HEADERS["User-Agent"],
            "Referer": "https://asd.pics/"
        }, timeout=10, allow_redirects=True)
        m3u8 = re.findall(r'https?://[^\s"\'\\<>]+\.m3u8[^\s"\'\\<>]*', r.text)
        mp4  = re.findall(r'https?://[^\s"\'\\<>]+\.mp4[^\s"\'\\<>]*',  r.text)
        url  = m3u8[0] if m3u8 else (mp4[0] if mp4 else "")
        return {"url": url, "type": "m3u8" if m3u8 else "mp4"}
    except:
        return {}

