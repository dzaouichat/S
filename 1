@app.route("/list")
def list_content():
    ctype = request.args.get("type","movies")
    page  = request.args.get("page",1,type=int)
    path  = CATEGORIES.get(ctype, CATEGORIES["movies"])
    url   = BASE + path + (f"page/{page}/" if page > 1 else "")
    r     = get_page(url)
    if not r:
        return jsonify({"error":"فشل الاتصال","results":[],"count":0}),500
    items = parse_content_list(r.text)
    return jsonify({"type":ctype,"page":page,"count":len(items),"results":items})

@app.route("/video")
def get_video():
    url = unquote(request.args.get("url",""))
    if not url:
        return jsonify({"error":"أرسل ?url=رابط"}),400
    r = get_page(url)
    if not r:
        return jsonify({"error":"فشل الاتصال"}),500
    csrf, post_id = extract_meta(r.text)
    if not post_id:
        return jsonify({"error":"لم يتم العثور على post_id"}),404
    servers_data = get_servers(post_id, csrf)
    return jsonify({"url":url,"post_id":post_id,"csrf":csrf,"servers":servers_data})

@app.route("/direct")
def get_direct():
    """الـ endpoint الجديد - يرجع رابط مباشر بدون iframe"""
    url     = unquote(request.args.get("url",""))
    quality = request.args.get("quality","720")
    server  = request.args.get("server","1")
    if not url:
        return jsonify({"error":"أرسل ?url=رابط"}),400
    r = get_page(url)
    if not r:
        return jsonify({"error":"فشل الاتصال"}),500
    csrf, post_id = extract_meta(r.text)
    # جلب embed url
    watch_data = get_watch_server(post_id, quality, server, csrf)
    embed_url  = watch_data.get("iframe_src","")
    if not embed_url:
        return jsonify({"error":"لم يتم العثور على سيرفر"}),404
    # استخراج الرابط المباشر
    direct = extract_direct_url(embed_url)
    # إضافة اسم السيرفر
    for name in ["vidara","vidmoly","voe"]:
        if name in embed_url:
            direct["name"] = f"▶ {name}"
            break
    else:
        direct["name"] = f"سيرفر {server}"
    direct["embed"] = embed_url
    return jsonify(direct)

